<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="admin/tool/coursearchiver/db"
       VERSION="2025060204"
       COMMENT="XMLDB file for tool_coursearchiver"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

    <!-- ===================================================== -->
    <!-- Existing tables (DO NOT REMOVE) -->
    <!-- ===================================================== -->

    <TABLES>

        <TABLE NAME="tool_coursearchiver_optout" COMMENT="Course opt-out records">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="optouttime" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="optoutlength" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="tool_coursearchiver_saves" COMMENT="Saved archive states">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="content" TYPE="text" LENGTH="big" NOTNULL="false"/>
                <FIELD NAME="step" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="savedate" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="tool_coursearchiver_archived" COMMENT="Archived course backups">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="owners" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="timetodelete" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- ===================================================== -->
        <!-- NEW: Archive run log (Added by Mujahidul Islam) -->
        <!-- ===================================================== -->

        <TABLE NAME="tool_coursearchiver_log" COMMENT="Course archive run log">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="runid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="coursename" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="backupfile" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="errormessage" TYPE="text" LENGTH="big" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="runid_idx" UNIQUE="false" FIELDS="runid"/>
                <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
            </INDEXES>
        </TABLE>

        <!-- ===================================================== -->
        <!-- NEW: S3 sync tracking (Added by Mujahidul Islam) -->
        <!-- ===================================================== -->

        <TABLE NAME="tool_coursearchiver_s3sync" COMMENT="S3 sync tracking">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="term" TYPE="char" LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timestarted" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timefinished" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="error" TYPE="text" LENGTH="big" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="idx_term" UNIQUE="false" FIELDS="term"/>
                <INDEX NAME="idx_status" UNIQUE="false" FIELDS="status"/>
            </INDEXES>
        </TABLE>

    </TABLES>

</XMLDB>

